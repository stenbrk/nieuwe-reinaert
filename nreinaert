    r: 12,
    vx: 0,
    vy: 0
  };
} else {
  player2 = null;
}

  enemies = [];
  collectibles = [];
  score = 0;
  spawnTimer = 0;
  gameRunning = true;
  powerupSpawnedFor20 = 0;

  for (let i = 0; i < coinsInGame; i++) {
  spawnCollectible();
}

  document.getElementById("overlay").style.display = "none";
}

function gameOver() {
  gameRunning = false;


  // RESET ALLE POWERUPS
  magnetActive = false;
  magnetTimer = 0;

  shieldActive = false;
  shieldTimer = 0; 

  coinMultiplierActive = false;
  coinMultiplierTimer = 0;

  coinBombActive = false;
  coinsInGame = 4;

  if (score > highscore) highscore = score;

  const music = document.getElementById("bgMusic");
  music.pause();
  music.currentTime = 0;

  playBeep(120, 0.3, "square", 0.2);

  document.getElementById("overlay").style.display = "flex";
  document.getElementById("titleText").innerText = "Game Over";
  document.getElementById("startBtn").innerText = "Play again";
  
  coins += score;
}
const POWERUPS = ["magnet", "shield", "coinbomb"];

function updateLeaderboardUI() {
  let lb = document.getElementById("leaderboard");

  // FILTER: per speler alleen hoogste score
  let filtered = {};
  leaderboard.forEach(entry => {
    if (!filtered[entry.name] || entry.score > filtered[entry.name].score) {
      filtered[entry.name] = entry;
    }
  });

  let uniqueLeaderboard = Object.values(filtered);

  // SORT op score
  uniqueLeaderboard.sort((a, b) => b.score - a.score);

  // TOP 10
  let top10 = uniqueLeaderboard.slice(0, 10);

  let html = "<h3>Leaderboard</h3>";

  top10.forEach((entry, i) => {
    let badge = "";
    if (i === 0) badge = "🥇 ";
    if (i === 1) badge = "🥈 ";
    if (i === 2) badge = "🥉 ";

    html += `<div>${badge}${i + 1}. ${entry.name} (${entry.score} punten)</div>`;
  });

  // JOUW score
  let yourEntry = uniqueLeaderboard.find(e => e.name === playerName);
  if (yourEntry) {
    let yourIndex = uniqueLeaderboard.indexOf(yourEntry);
    html += `<br><div><b>👤 ${playerName}: ${yourEntry.score} (${yourIndex + 1}e plaats)</b></div>`;
  }

  lb.innerHTML = html;
}

function spawnCollectible() {
  let y = 100 + Math.random() * 280;
  collectibles.push({
    x: Math.random() * 380,
    y: y,
    r: 6
  });
}

function spawnPowerup() {
  let y = 100 + Math.random() * 280;
  let type = POWERUPS[Math.floor(Math.random() * POWERUPS.length)];

  collectibles.push({
    x: Math.random() * 380,
    y: y,
    r: 14,
    type: type
  });
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

function update() {
  if (!gameRunning || !player) return;
  
  if (magnetActive) {
  magnetTimer -= 16;

  collectibles.forEach(c => {
    if (c.type === "coin") {
      let dx = player.x - c.x;
      let dy = player.y - c.y;
      let dist = Math.hypot(dx, dy);

      if (dist < 120) {
        c.x += dx * 0.05;
        c.y += dy * 0.05;
      }
    }
  });

  if (magnetTimer <= 0) magnetActive = false;
}

if (shieldActive) {
  shieldTimer -= 16;
  if (shieldTimer <= 0) shieldActive = false;
}

    if (coinMultiplierActive) {
  coinMultiplierTimer -= 16;
  if (coinMultiplierTimer <= 0) coinMultiplierActive = false;
}

  let accel = 0.8;
  
  let baseSpeed;
  baseSpeed = (gameMode === "hard" ? 8 : 4) * playerSpeedMultiplier;

if (gameMode === "hard") {
  baseSpeed = 8;
} else {
  baseSpeed = 4; // normaal langzamer
}

// PLAYER 1
if (playerMode === "1") {
  // beide werken voor 1 player
  if (keys["w"] || keys["arrowup"]) player.vy -= accel;
  if (keys["s"] || keys["arrowdown"]) player.vy += accel;
  if (keys["a"] || keys["arrowleft"]) player.vx -= accel;
  if (keys["d"] || keys["arrowright"]) player.vx += accel;
} else {
  // 2 players
  if (keys["w"]) player.vy -= accel;
  if (keys["s"]) player.vy += accel;
  if (keys["a"]) player.vx -= accel;
  if (keys["d"]) player.vx += accel;
}

// PLAYER 2
if (playerMode === "2" && player2) {
  if (keys["arrowup"]) player2.vy -= accel;
  if (keys["arrowdown"]) player2.vy += accel;
  if (keys["arrowleft"]) player2.vx -= accel;
  if (keys["arrowright"]) player2.vx += accel;

  player2.vx *= 0.9;
  player2.vy *= 0.9;

  player2.x += player2.vx;
  player2.y += player2.vy;

  player2.x = Math.max(0, Math.min(400, player2.x));
  player2.y = Math.max(0, Math.min(400, player2.y));
}

  player.vx *= 0.9;
  player.vy *= 0.9;

  player.x += player.vx;
  player.y += player.vy;

  player.x = Math.max(0, Math.min(400, player.x));
  player.y = Math.max(0, Math.min(400, player.y));

  spawnTimer += 16;

  let spawnRate;

if (gameMode === "hard") {
  // HARD = sneller spawnen
  spawnRate = 1200;

  if (score > 5) spawnRate = 800;
  if (score > 10) spawnRate = 500;
  if (score > 20) spawnRate = 250;

} else {
  //  NORMAL = langzamer
  spawnRate = 2500;

  if (score > 5) spawnRate = 1800;
  if (score > 10) spawnRate = 1200;
  if (score > 20) spawnRate = 800;
}

  if (spawnTimer > spawnRate) {
  spawnTimer = 0;

  let spawnX = Math.random() * 400;
  let spawnY = -20;

  let types = ["nobel", "bear", "wolf", "cat", "ram"];
let type = types[Math.floor(Math.random() * types.length)];

enemies.push({
  x: spawnX,
  y: spawnY,
  r: 8,
  speed: baseSpeed + score * 0.07,
  type: type
});
}

  enemies.forEach(e => {
  e.y += e.speed;

  // PLAYER 1
  let dx1 = player.x - e.x;
  let dy1 = player.y - e.y;
  let dist1 = Math.hypot(dx1, dy1);

  if (dist1 < player.r + e.r) {
    if (!shieldActive) gameOver();
  }

  // PLAYER 2
  if (player2) {
    let dx2 = player2.x - e.x;
    let dy2 = player2.y - e.y;
    let dist2 = Math.hypot(dx2, dy2);

    if (dist2 < player2.r + e.r) {
      gameOver();
    }
  }
});

  enemies = enemies.filter(e => e.y < 450);

  collectibles = collectibles.filter(c => {

  let dx1 = player.x - c.x;
  let dy1 = player.y - c.y;
  let dist1 = Math.hypot(dx1, dy1);

  let hitPlayer2 = false;
  let dist2 = Infinity;

  if (player2) {
    let dx2 = player2.x - c.x;
    let dy2 = player2.y - c.y;
    dist2 = Math.hypot(dx2, dy2);
    hitPlayer2 = dist2 < player2.r + c.r;
  }

  if (dist1 < player.r + c.r || hitPlayer2) {

  // COIN
  if (c.type === "coin" || !c.type) {
  if (coinMultiplierActive) {
    score += 2;
  } else {
    score += 1;
  }
    playBeep(600, 0.1, "triangle", 0.1);

    if (coinBombActive) {
      coinsInGame--;

      if (coinsInGame <= 4) {
        coinBombActive = false;
        coinsInGame = 4;
      }
    }
  }

  // MAGNET
  if (c.type === "magnet") {
    coinMultiplierActive = true;
    coinMultiplierTimer = 10000;
    playBeep(300, 0.2, "sine", 0.2);
  }

  // SHIELD
  if (c.type === "shield") {
    shieldActive = true;
    shieldTimer = 10000;
    playBeep(800, 0.2, "square", 0.2);
  }

  // COINBOMB
  if (c.type === "coinbomb") {
    coinBombActive = true;
    coinsInGame = 14;
    playBeep(200, 0.3, "square", 0.3);
  }

  spawnCollectible();
  return false;
}
    return true;
  });
  
  if (score >= 20 && Math.floor(score / 20) > powerupSpawnedFor20) {
  spawnPowerup();
  powerupSpawnedFor20 = Math.floor(score / 20);
}

  // Altijd vullen tot coinsInGame
while (collectibles.length < coinsInGame) spawnCollectible();

// Als coinBomb actief en alle coins gepakt
if (coinBombActive && collectibles.length <= 3) {
  coinBombActive = false;
  coinsInGame = 4;
}

  document.getElementById("scoreDisplay").innerText =
  "Score: " + score + " | Highscore: " + highscore + " | 🐤: " + coins;
}

particles.forEach(p => {
  p.x += p.dx;
  p.y += p.dy;
  p.life--;
});

particles = particles.filter(p => p.life > 0);

function draw() {
  ctx.fillStyle = "#022c22";
  ctx.fillRect(0,0,400,400);
  
  // PLAYER 1 🦊 (Reinaert)
if (player) {
  ctx.save();

  ctx.textAlign = "center";
  ctx.textBaseline = "middle";


  // de vos zelf
  ctx.font = "32px Arial";
  ctx.shadowBlur = 15;
ctx.shadowColor = "#fa4402";


// SKINS
if (selectedSkin === "basic") {
  ctx.shadowColor = "#fa4402";
  ctx.shadowBlur = 15;
  ctx.fillText("🦊", player.x, player.y);
  
  ctx.fillStyle = "#FF8C00";
  ctx.font = "14px Arial";
  ctx.fillText("Reinaert", player.x, player.y - 24);
}

else if (selectedSkin === "kingfox") {
  // gouden glow
  ctx.shadowColor = "gold";
  ctx.shadowBlur = 20;

  

  // vos
  ctx.font = "32px Arial";
  ctx.fillText("🦊", player.x, player.y);
  
  // kroon
  ctx.font = "20px Arial";
  ctx.fillText("👑", player.x, player.y - 15);
  
  ctx.fillStyle = "#FF8C00";
  ctx.font = "14px Arial";
  ctx.fillText("Reinaert", player.x, player.y - 34);
}

else if (selectedSkin === "nightfox") {
  ctx.shadowColor = "black";
ctx.shadowBlur = 25;

ctx.globalAlpha = 0.35; // maakt hem donkerder
ctx.fillText("🦊", player.x, player.y);
ctx.globalAlpha = 8;

ctx.fillStyle = "#FF8C00";
  ctx.font = "14px Arial";
  ctx.fillText("Reinaert", player.x, player.y - 24);

  ctx.fillStyle = "white"; // reset voor andere dingen
}

ctx.shadowBlur = 0;


  ctx.restore();

// PLAYER 2 🦡 (bijv. "Buur")
if (player2) {
  ctx.save();

  ctx.textAlign = "center";
  ctx.textBaseline = "middle";

  // naam boven de emoji
  ctx.fillStyle = "#807878";
  ctx.font = "14px Arial";
  ctx.fillText("Grimbeert", player2.x, player2.y - 20);

  // de emoji zelf
  ctx.font = "40px Arial";

// 🔥 GLOW EFFECT
ctx.shadowBlur = 15;
ctx.shadowColor = "grey";

ctx.fillText("🦡", player2.x, player2.y);

// reset (belangrijk!)
ctx.shadowBlur = 0;

  ctx.restore();
}
  
  

  // 🔽 TIMER IN DE SPeler
  if (shieldActive) {
    ctx.fillStyle = "black";
    ctx.font = "bold 17px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";

    ctx.fillText(
      Math.ceil(shieldTimer / 1000),
      player.x,
      player.y
    );
 }
    
    if (coinMultiplierActive) {
  ctx.fillStyle = "black";
  ctx.font = "bold 17px Arial";
  ctx.textAlign = "center";
  ctx.textBaseline = "middle";

  ctx.fillText(
    Math.ceil(coinMultiplierTimer / 1000),
    player.x,
    player.y
  );
  }
}
  
  if (shieldActive) {
  ctx.beginPath();
  ctx.strokeStyle = "cyan";
  ctx.lineWidth = 3;
  ctx.arc(player.x, player.y, player.r + 8, 0, Math.PI * 2);
  ctx.stroke();
}

  enemies.forEach(e => {
  drawEnemy(e, true); // true = glow aan
});

  collectibles.forEach(c=>{
  ctx.beginPath();
  ctx.arc(c.x, c.y, c.r, 0, Math.PI * 2);

  // MAGNET (coin multiplier)
  if (c.type === "magnet") {
    ctx.fillStyle = "blue"; // blauw
    ctx.fill();

    ctx.fillStyle = "white";
    ctx.font = "18px Serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("X2", c.x, c.y);
  }

  // COINBOMB
  else if (c.type === "coinbomb") {
    ctx.fillStyle = "orange";
    ctx.fill();

    ctx.fillStyle = "black";
    ctx.font = "18px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("💣", c.x, c.y);
  }

  // SHIELD
  else if (c.type === "shield") {
    ctx.fillStyle = "blue";
    ctx.fill();

    ctx.fillStyle = "white";
    ctx.font = "18px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("🛡", c.x, c.y);
  }

// NORMAL COIN
else {
  // 🐤 KUIKEN (emoji zonder achtergrond)
  ctx.font = "20px Arial";
  ctx.textAlign = "center";
  ctx.textBaseline = "middle";
  ctx.fillText("🐤", c.x, c.y);
}
});

function spawnParticles(x, y, color = "yellow") {
  for (let i = 0; i < 8; i++) {
    particles.push({
      x: x,
      y: y,
      dx: (Math.random() - 0.5) * 4,
      dy: (Math.random() - 0.5) * 4,
      life: 30,
      color: color
    });
  }
}

particles.forEach(p => {
  ctx.fillStyle = p.color;
  ctx.fillRect(p.x, p.y, 3, 3);
});

function drawEnemy(e, glow = false) {
  ctx.save();

  ctx.textAlign = "center";
  ctx.textBaseline = "middle";

  if (glow) {
    ctx.shadowBlur = 15;
    if (e.type === "nobel") ctx.shadowColor = "gold";
else if (e.type === "bear") ctx.shadowColor = "#805959";
else if (e.type === "wolf") ctx.shadowColor = "gray";
else if (e.type === "ram") ctx.shadowColor = "white";
else if (e.type === "cat") ctx.shadowColor = "yellow";
else ctx.shadowColor = "red";
  }

  // 🦁 NOBEL
  if (e.type === "nobel") {
    ctx.fillStyle = "#FFD700";
    ctx.font = "15px Arial";
    ctx.fillText("Nobel", e.x, e.y - 42);

    ctx.font = "30px Arial";
    ctx.fillText("👑", e.x, e.y - 18);

    ctx.fillText("🦁", e.x, e.y);
  }

  // 🐻 BEAR
  else if (e.type === "bear") {
    ctx.fillStyle = "#9c7878";
    ctx.font = "15px Arial";
    ctx.fillText("Bruun", e.x, e.y - 28);

    ctx.font = "30px Arial";
    ctx.fillText("🐻", e.x, e.y);
  }

  // 🐺 WOLF
  else if (e.type === "wolf") {
    ctx.fillStyle = "#ababab";
    ctx.font = "15px Arial";
    ctx.fillText("Isengrim", e.x, e.y - 26);

    ctx.font = "30px Arial";
    ctx.fillText("🐺", e.x, e.y);
  }

  // 🐑 RAM
  else if (e.type === "ram") {
    ctx.fillStyle = "white";
    ctx.font = "15px Arial";
    ctx.fillText("Belijn", e.x, e.y - 27);

    ctx.font = "30px Arial";
    ctx.fillText("🐑", e.x, e.y);
  }

  // 🐱 CAT
  else if (e.type === "cat") {
    ctx.fillStyle = "#FFD700";
    ctx.font = "15px Arial";
    ctx.fillText("Tibert", e.x, e.y - 26);

    ctx.font = "30px Arial";
    ctx.fillText("🐱", e.x, e.y);
  }

  else {
    ctx.beginPath();
    ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
    ctx.fillStyle = "red";
    ctx.fill();
  }

  ctx.shadowBlur = 0;
  ctx.restore();
}
}


loop();
listenLeaderboard();
</script>

