function openSettings() {
  document.getElementById("settingsOverlay").style.display = "flex";
}

function closeSettings() {
  document.getElementById("settingsOverlay").style.display = "none";
}

const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function playBeep(freq, duration, type="sine", volume=0.1) {
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();

  osc.type = type;
  osc.frequency.value = freq;
  gain.gain.value = volume;

  osc.connect(gain);
  gain.connect(audioCtx.destination);

  osc.start();
  osc.stop(audioCtx.currentTime + duration);
}

document.addEventListener("keydown", e => keys[e.key.toLowerCase()] = true);
document.addEventListener("keyup", e => keys[e.key.toLowerCase()] = false);

document.getElementById("startBtn").onclick = () => startGame();
document.getElementById("settingsBtn").onclick = () => openSettings();
document.getElementById("volumeSlider").oninput = (e) => {
  volume = e.target.value;
  document.getElementById("bgMusic").volume = volume;
};

document.getElementById("playerMode").onchange = (e) => {
  playerMode = e.target.value;
};

document.getElementById("shopBtn").onclick = () => openShop();

function openShop() {
  document.getElementById("shopOverlay").style.display = "flex";
  updateShop();
}

function closeShop() {
  document.getElementById("shopOverlay").style.display = "none";
}

function updateShop() {
  document.getElementById("coinsDisplay").innerText = "🐤: " + coins;

  const skinsDiv = document.getElementById("skinsRow");
  const powerupsDiv = document.getElementById("powerupsRow");

  skinsDiv.innerHTML = "";
  powerupsDiv.innerHTML = "";

  shopItemsData.forEach(item => {
    const btn = document.createElement("div");

    btn.style.padding = "10px";
    btn.style.width = "90px";
    btn.style.height = "120px";
    btn.style.border = "2px solid white";
    btn.style.borderRadius = "10px";
    btn.style.display = "flex";
    btn.style.flexDirection = "column";
    btn.style.alignItems = "center";
    btn.style.justifyContent = "center";
    btn.style.cursor = "pointer";
    btn.style.transition = "0.2s";

    btn.onmouseover = () => btn.style.transform = "scale(1.1)";
    btn.onmouseout = () => btn.style.transform = "scale(1)";

    // geselecteerde skin highlight
    if (selectedSkin === item.id) {
      btn.style.border = "3px solid gold";
    }

    // skin emoji
    if (item.type === "skin") {
      const emojiDiv = document.createElement("div");
      emojiDiv.style.fontSize = "40px";
      emojiDiv.innerText = item.emoji;
      btn.appendChild(emojiDiv);
    }

    // naam
    const nameDiv = document.createElement("div");
    nameDiv.style.fontSize = "14px";
    nameDiv.style.marginTop = "5px";
    nameDiv.innerText = item.name;
    btn.appendChild(nameDiv);

    // ALS JE HEM HEBT
    if (ownedItems[item.id]) {

      if (selectedSkin === item.id) {
        const selectedText = document.createElement("div");
        selectedText.innerText = "🎯 Selected";
        selectedText.style.fontSize = "12px";
        selectedText.style.marginTop = "5px";
        btn.appendChild(selectedText);
      } else {
        const selectBtn = document.createElement("button");
        selectBtn.innerText = "Select";
        selectBtn.style.fontSize = "12px";
        selectBtn.style.marginTop = "5px";

        selectBtn.onclick = (e) => {
          e.stopPropagation(); // voorkomt kopen
          selectedSkin = item.id;
          updateShop();
        };

        btn.appendChild(selectBtn);
      }

    } else {
      // prijs tonen
      const priceDiv = document.createElement("div");
      priceDiv.style.fontSize = "12px";
      priceDiv.style.marginTop = "5px";
      priceDiv.innerText = item.price + " 🐤";
      btn.appendChild(priceDiv);
    }

    // kopen door op item te klikken
    btn.onclick = () => buyItem(item);

    // juiste sectie
    if (item.type === "skin") {
      skinsDiv.appendChild(btn);
    } else {
      powerupsDiv.appendChild(btn);
    }
  });
}

function buyItem(item) {
  if (ownedItems[item.id]) return;

  if (coins >= item.price) {
    coins -= item.price;
    ownedItems[item.id] = true;
    updateShop();
    playBeep(800, 0.2, "square", 0.2);
  } else {
    alert("Niet genoeg 🐤!");
    playBeep(200, 0.2, "sawtooth", 0.2);
  }
}


